{
	"$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
	"files": {
		"includes": [
			"src/**",
			"scripts/**",
			"drizzle.config.ts",
			"!**/node_modules",
			"!src/ui",
			"!**/__golden__"
		]
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error",
				"noUnusedFunctionParameters": "error",
				"noUnusedPrivateClassMembers": "error"
			},
			"suspicious": {
				"noExplicitAny": "error"
			},
			"style": {
				"noNonNullAssertion": "error",
				"useConst": "error",
				"useImportType": "error",
				"useExportType": "error",
				"useNodejsImportProtocol": "error",
				"useTemplate": "error"
			},
			"complexity": {
				"noUselessTypeConstraint": "error",
				"noExcessiveLinesPerFunction": {
					"level": "error",
					"options": { "maxLines": 500 }
				}
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"overrides": [
		{
			"includes": [
				"src/client/client.test.ts",
				"src/preview/launch.test.ts",
				"src/registry/refresh.test.ts",
				"src/runs/reap.test.ts",
				"src/runs/reap.ts",
				"src/runs/spawn.test.ts",
				"src/runs/stream.test.ts",
				"src/server/handlers.plan-runs.test.ts"
			],
			"linter": {
				"rules": {
					"complexity": {
						"noExcessiveLinesPerFunction": "off"
					}
				}
			}
		}
	]
}
