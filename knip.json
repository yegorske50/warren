{
	"$schema": "https://unpkg.com/knip@6/schema.json",
	"ignore": [
		".bun/**",
		"data/**",
		"dist/**",
		"src/ui/dist/**",
		"src/db/migrations/**"
	],
	"workspaces": {
		".": {
			"entry": [
				"src/server/**/*.ts",
				"scripts/**/*.ts",
				"drizzle.config.*.ts",
				"**/*.test.ts"
			],
			"project": ["src/**/*.ts", "scripts/**/*.ts"],
			"ignore": ["src/ui/**"]
		},
		"src/ui": {
			"entry": ["index.html"],
			"project": ["src/**/*.{ts,tsx}"]
		}
	}
}
